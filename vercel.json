{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/ai.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "ai-service/**",
          "data/**",
          "outputs/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/ai/(.*)",
      "dest": "api/ai.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
